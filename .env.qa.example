# QA 검증용 운영 DB 접속 정보 — 이 파일을 복사해서 사용:
#   cp .env.qa.example .env.qa && chmod 600 .env.qa
# ⚠ .env.qa 는 gitignore 됨. 실제 값을 이 example 파일이나 채팅·커밋에 절대 넣지 말 것.

# SSH 터널 (DB 가 SSH 뒤에 있을 때)
SSH_HOST=ec2-xx-xx-xx-xx.ap-northeast-2.compute.amazonaws.com
SSH_USER=ubuntu
SSH_KEY=~/.ssh/allcll-prod.pem
SSH_PORT=22

# SSH 서버에서 바라본 DB 위치 (같은 서버면 127.0.0.1, RDS 면 엔드포인트)
PROD_DB_HOST=127.0.0.1
PROD_DB_PORT=3306
PROD_DB_USER=readonly_qa        # SELECT 권한만 있는 계정 권장
PROD_DB_PASSWORD=               # 비우면 실행 시 프롬프트
PROD_DB_NAME=allcll

# 로컬 복원 대상
QA_DB_NAME=allcll_qa
LOCAL_MYSQL_USER=root
LOCAL_MYSQL_PASSWORD=           # ⚠ 이 example 파일엔 실제 값 금지 (커밋됨) — .env.qa 에만
